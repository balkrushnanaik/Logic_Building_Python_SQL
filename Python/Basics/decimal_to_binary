def decimal_to_binary(n):
    if n == 0:
        return "0"
    negative = n < 0
    n = abs(n)
    binary_digits = []
    while n > 0:
        binary_digits.append(str(n % 2))
        n //= 2
    binary = "".join(reversed(binary_digits))
    return "-" + binary if negative else binary


def main():
    try:
        decimal_number = int(input("Enter a decimal number: "))
    except ValueError:
        print("Please enter a valid integer.")
        return
    print(f"Binary representation: {decimal_to_binary(decimal_number)}")


if __name__ == "__main__":
    main()
