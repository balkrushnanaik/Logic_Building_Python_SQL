def gcd(a, b):
    while b:
        a, b = b, a % b
    return abs(a)

if __name__ == "__main__":
    try:
        x = int(input("Enter first number: "))
        y = int(input("Enter second number: "))
    except ValueError:
        print("Please enter valid integers.")
    else:
        print(f"GCD of {x} and {y} is {gcd(x, y)}")


